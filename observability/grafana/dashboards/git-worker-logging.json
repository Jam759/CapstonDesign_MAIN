      },
      "id": 1,
      "options": {
        "content": "### Filters\\n- `traceId`: 특정 비동기 작업 추적용 trace ID\\n- `containsText`: jobId, eventType, 에러 코드 같은 문자열\\n- `pathFilter`: worker HTTP endpoint 경로 필터\\n- `minDurationMs`: 느린 worker HTTP 요청 기준값",
        "mode": "markdown"
      },
      "pluginVersion": "12.3.1",
      "title": "Dashboard Filters",
      "type": "text"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{job=\"git-worker-application\"} |= \"${containsText}\" |= \"${traceId}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Worker App Logs",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 3,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{job=\"git-worker-structured-http\", event_type=\"HTTP_ERROR\"} |= \"${pathFilter}\" |= \"${traceId}\" | json method=\"http.method\", path=\"http.path\", status=\"http.status\", duration=\"durationMs\", trace_id=\"traceId\", error_code=\"error.code\", error_message=\"error.message\" | line_format \"{{.status}} {{.method}} {{.path}} {{.duration}}ms error={{.error_code}} trace={{.trace_id}} {{.error_message}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Worker HTTP Errors",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{job=\"git-worker-structured-http\", event_type=~\"HTTP_RESPONSE|HTTP_ERROR\"} |= \"${pathFilter}\" |= \"${traceId}\" | json method=\"http.method\", path=\"http.path\", status=\"http.status\", duration=\"durationMs\", trace_id=\"traceId\", class_name=\"className\", handler_method=\"method\", msg=\"message\" | duration >= ${minDurationMs} | line_format \"{{.duration}}ms {{.status}} {{.method}} {{.path}} trace={{.trace_id}} {{.class_name}}.{{.handler_method}} {{.msg}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Slow Worker HTTP Requests",
      "type": "logs"
    }
  ],
